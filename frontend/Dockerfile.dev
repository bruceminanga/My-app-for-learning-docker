FROM node:22.14.0-alpine@sha256:01393fe5a51489b63da0ab51aa8e0a7ff9990132917cf20cfc3d46f5e36c0e48

ARG GIT_SHA=unknown
ARG VERSION=1.0.0
ARG MAINTAINER="bruce@bruceminanga.world"

LABEL org.opencontainers.image.revision="${GIT_SHA}" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.authors="${MAINTAINER}" \
      org.opencontainers.image.base.name="node:22.14.0-alpine"

WORKDIR /app

# Give the node user ownership of the workdir before installing
RUN chown node:node /app

# Switch early — everything from here runs as node
USER node

# Manifests first — cached until package.json or package-lock.json changes
COPY --chown=node:node package*.json ./

# node_modules will now be owned by node from the start
RUN npm ci --prefer-offline

COPY --chown=node:node . .

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]